<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <title>Version History</title>
</head>
<body>
  <%- include("./partials/nav") %>

  <div class="page-wrap">
    <div class="page-card">
      <div class="d-flex justify-content-between align-items-center mb-4 gap-3 flex-wrap">
        <div>
          <div class="section-title">Timeline</div>
          <h1 class="page-heading" style="font-size: 2.2rem;">Version History</h1>
        </div>
        <a href="/blog/<%= blog.slug || blog._id %>" class="ghost-btn">Back to Blog</a>
      </div>

      <div class="d-grid gap-3">
        <% versions.forEach(version => { %>
          <div class="section-card">
            <div class="d-flex justify-content-between mb-2 gap-3 flex-wrap">
              <strong><%= version.title %></strong>
              <span class="soft-muted small"><%= new Date(version.updatedAt).toLocaleString() %></span>
            </div>
            <div class="small soft-muted mb-2"><%= version.category || "General" %></div>
            <div style="white-space: pre-wrap;"><%= version.body %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <%- include("./partials/scripts") %>
</body>
</html>
