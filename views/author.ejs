<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <title><%= author.fullName %></title>
</head>
<body>
  <%- include("./partials/nav") %>

  <div class="page-wrap d-grid gap-4">
    <section class="page-card">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3">
          <img src="<%= author.profileImageURL %>" width="84" height="84" class="rounded-circle" alt="<%= author.fullName %>">
          <div>
            <div class="section-title mb-2">Author Profile</div>
            <h1 class="page-heading" style="font-size: 2.2rem;"><%= author.fullName %></h1>
            <p class="page-subtitle"><%= author.email %></p>
          </div>
        </div>
        <div class="d-flex gap-3 flex-wrap">
          <div class="metric-card" style="min-width: 180px;">
            <div class="section-title mb-2">Published Blogs</div>
            <div class="metric-value"><%= totalBlogs || blogs.length %></div>
          </div>
          <div class="metric-card metric-card--accent" style="min-width: 180px;">
            <div class="section-title mb-2" style="color: rgba(255,255,255,0.8);">Total Views</div>
            <div class="metric-value"><%= totalViews || 0 %></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-card">
      <div class="panel__header">
        <h2 class="panel__title">Published Blogs</h2>
        <span class="soft-muted small">Articles by this author</span>
      </div>
      <div class="row g-3">
        <% blogs.forEach(blog => { %>
          <div class="col-md-6 col-xl-4">
            <article class="card-glass h-100">
              <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" style="width:100%; height:190px; object-fit:cover;">
              <div class="p-3 d-flex flex-column gap-2">
                <span class="mini-pill"><%= blog.category || "General" %></span>
                <h3 class="h4 mb-1"><%= blog.title %></h3>
                <a href="/blog/<%= blog.slug || blog._id %>" class="brand-btn mt-auto">View</a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </section>
  </div>

  <%- include("./partials/scripts") %>
</body>
</html>
